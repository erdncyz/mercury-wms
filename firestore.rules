rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isNonEmptyString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function isString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function isValidProductData(data) {
      return data.keys().hasOnly([
          'name',
          'barcode',
          'labelNumber',
          'category',
          'quantity',
          'price',
          'imageUrl',
          'details',
          'updatedAt'
        ])
        && isNonEmptyString(data.name, 120)
        && isString(data.barcode, 80)
        && (!data.keys().hasAny(['labelNumber']) || isString(data.labelNumber, 80))
        && isNonEmptyString(data.category, 80)
        && data.quantity is number
        && data.quantity >= 0
        && data.price is number
        && data.price >= 0
        && (!data.keys().hasAny(['imageUrl']) || data.imageUrl is string)
        && (!data.keys().hasAny(['details']) || isValidProductDetails(data.details))
        && data.updatedAt is timestamp;
    }

    function isValidProductDetails(details) {
      return details is map
        && details.keys().hasOnly([
          'productCode',
          'imageRef',
          'features',
          'warehouseLocation',
          'containerNumber',
          'totalProductCount',
          'qtyPerBox',
          'totalBox',
          'unitKg',
          'totalKg',
          'widthCm',
          'lengthCm',
          'heightCm',
          'unitM3',
          'totalM3'
        ])
        && (!details.keys().hasAny(['productCode']) || details.productCode is string)
        && (!details.keys().hasAny(['imageRef']) || details.imageRef is string)
        && (!details.keys().hasAny(['features']) || details.features is string)
        && (!details.keys().hasAny(['warehouseLocation']) || details.warehouseLocation is string)
        && (!details.keys().hasAny(['containerNumber']) || details.containerNumber is string)
        && (!details.keys().hasAny(['totalProductCount']) || details.totalProductCount is number)
        && (!details.keys().hasAny(['qtyPerBox']) || details.qtyPerBox is number)
        && (!details.keys().hasAny(['totalBox']) || details.totalBox is number)
        && (!details.keys().hasAny(['unitKg']) || details.unitKg is number)
        && (!details.keys().hasAny(['totalKg']) || details.totalKg is number)
        && (!details.keys().hasAny(['widthCm']) || details.widthCm is number)
        && (!details.keys().hasAny(['lengthCm']) || details.lengthCm is number)
        && (!details.keys().hasAny(['heightCm']) || details.heightCm is number)
        && (!details.keys().hasAny(['unitM3']) || details.unitM3 is number)
        && (!details.keys().hasAny(['totalM3']) || details.totalM3 is number);
    }

    function isValidStockLogData(data) {
      return data.keys().hasOnly([
          'productId',
          'productName',
          'type',
          'amount',
          'destination',
          'dealerId',
          'dealerName',
          'timestamp'
        ])
        && isNonEmptyString(data.productId, 128)
        && isNonEmptyString(data.productName, 120)
        && (data.type == 'IN' || data.type == 'OUT')
        && data.amount is number
        && data.amount > 0
        && (!data.keys().hasAny(['destination']) || isString(data.destination, 200))
        && (!data.keys().hasAny(['dealerId']) || isString(data.dealerId, 128))
        && (!data.keys().hasAny(['dealerName']) || isString(data.dealerName, 160))
        && data.timestamp is timestamp;
    }

    function isValidDealerData(data) {
      return data.keys().hasOnly([
          'name',
          'code',
          'contactName',
          'phone',
          'email',
          'city',
          'address',
          'note',
          'updatedAt'
        ])
        && isNonEmptyString(data.name, 160)
        && (!data.keys().hasAny(['code']) || isString(data.code, 80))
        && (!data.keys().hasAny(['contactName']) || isString(data.contactName, 120))
        && (!data.keys().hasAny(['phone']) || isString(data.phone, 80))
        && (!data.keys().hasAny(['email']) || isString(data.email, 160))
        && (!data.keys().hasAny(['city']) || isString(data.city, 120))
        && (!data.keys().hasAny(['address']) || isString(data.address, 300))
        && (!data.keys().hasAny(['note']) || isString(data.note, 300))
        && data.updatedAt is timestamp;
    }

    function isValidActivityLogData(data) {
      return data.keys().hasOnly([
          'action',
          'productId',
          'productName',
          'amount',
          'destination',
          'source',
          'stockType',
          'beforeStock',
          'afterStock',
          'dealerId',
          'dealerName',
          'warehouseFrom',
          'warehouseTo',
          'barcode',
          'changedFields',
          'summary',
          'userId',
          'userName',
          'timestamp'
        ])
        && (data.action == 'create'
          || data.action == 'update'
          || data.action == 'delete'
          || data.action == 'stock_in'
          || data.action == 'stock_out')
        && isString(data.productId, 128)
        && isNonEmptyString(data.productName, 200)
        && data.amount is number
        && (!data.keys().hasAny(['destination']) || isString(data.destination, 200))
        && (!data.keys().hasAny(['source']) || isString(data.source, 80))
        && (!data.keys().hasAny(['stockType']) || data.stockType == 'IN' || data.stockType == 'OUT' || data.stockType == '')
        && (!data.keys().hasAny(['beforeStock']) || data.beforeStock is number)
        && (!data.keys().hasAny(['afterStock']) || data.afterStock is number)
        && (!data.keys().hasAny(['dealerId']) || isString(data.dealerId, 128))
        && (!data.keys().hasAny(['dealerName']) || isString(data.dealerName, 160))
        && (!data.keys().hasAny(['warehouseFrom']) || isString(data.warehouseFrom, 120))
        && (!data.keys().hasAny(['warehouseTo']) || isString(data.warehouseTo, 120))
        && (!data.keys().hasAny(['barcode']) || isString(data.barcode, 120))
        && (!data.keys().hasAny(['changedFields']) || (data.changedFields is list && data.changedFields.size() <= 30))
        && (!data.keys().hasAny(['summary']) || isString(data.summary, 300))
        && isString(data.userId, 128)
        && isString(data.userName, 200)
        && data.timestamp is timestamp;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProductData(request.resource.data);
      allow update: if isSignedIn() && isValidProductData(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /stock_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidStockLogData(request.resource.data);
      allow update, delete: if false;
    }

    match /dealers/{dealerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDealerData(request.resource.data);
      allow update: if isSignedIn() && isValidDealerData(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidActivityLogData(request.resource.data);
      allow update: if false;
      allow delete: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
